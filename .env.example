# App
SECRET_KEY=troque-por-uma-chave-secreta-longa-e-aleatoria
DEBUG=false
FRONTEND_URL=https://seu-frontend.vercel.app

# Criptografia de dados sensíveis (PIX/banco). Opcional — se vazio, deriva do SECRET_KEY.
# Para gerar uma chave Fernet: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

# PostgreSQL (local). Em produção, DATABASE_URL é injetada automaticamente.
DATABASE_URL=
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_USER=nail_user
POSTGRES_PASSWORD=nail_pass
POSTGRES_DB=nail_booking

# Redis
REDIS_URL=redis://redis:6379/0

# Asaas
ASAAS_API_KEY=sua_chave_asaas_aqui
ASAAS_ENVIRONMENT=sandbox
ASAAS_WEBHOOK_TOKEN=token-secreto-do-webhook

# Z-API (WhatsApp)
# ZAPI_API_URL   = "API da instância" no painel Z-API (ex: https://api.z-api.io)
# ZAPI_INSTANCE_ID = "ID da instância"
# ZAPI_TOKEN       = "Token da instância"
# ZAPI_CLIENT_TOKEN = "Client-Token" (segurança da conta, se habilitado)
ZAPI_API_URL=https://api.z-api.io
ZAPI_INSTANCE_ID=seu_id_da_instancia
ZAPI_TOKEN=seu_token_da_instancia
ZAPI_CLIENT_TOKEN=seu_client_token_se_tiver

# Resend (Email)
RESEND_API_KEY=re_sua_chave_resend
EMAIL_FROM=onboarding@resend.dev
EMAIL_FROM_NAME=Nail Studio

# Plataforma / Repasses
PLATFORM_FEE_PCT=20
PAYOUT_WEEKDAY=4

# Admin padrão (usado no seed)
ADMIN_EMAIL=admin@seudominio.com
ADMIN_PASSWORD=senha-segura-aqui
ADMIN_NAME=Administrador
